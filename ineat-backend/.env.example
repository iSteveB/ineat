# InEat backend environment example
# Copy this file to .env.development for local development.
# In production, configure these values in the hosting provider, for example Railway.

# Runtime
NODE_ENV=development
PORT=3000

# Database
# Required by Prisma v7 during install/build/generate and at runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ineat

# Queue
# Required because Bull is configured globally in AppModule.
REDIS_URL=redis://localhost:6379

# Auth
# Use long random values in real environments.
BETTER_AUTH_SECRET=replace-with-a-long-random-better-auth-secret
BETTER_AUTH_URL=http://localhost:3000

# CORS and OAuth redirects
# FRONTEND_URL and CORS_ORIGIN are used in production CORS.
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Google OAuth
# Optional unless Google login is enabled.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Cloudinary
# Required for avatar uploads.
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
CLOUDINARY_AVATAR_PRESET=replace-with-avatar-upload-preset

# Invoice Drive import analysis
# Use mock locally unless you want to call OpenAI for real PDF extraction.
INVOICE_ANALYSIS_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_INVOICE_MODEL=gpt-5.6-luna

# Sentry observability
# Optional; leave SENTRY_DSN empty to disable Sentry locally.
SENTRY_DSN=
SENTRY_ENABLE_LOGS=true
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=false
